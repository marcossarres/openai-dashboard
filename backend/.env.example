# Admin API key required for /v1/organization/costs
# Generate one at: https://platform.openai.com/api-keys
# (click "Create admin key", NOT a regular project key)
OPENAI_API_KEY=sk-admin-...
PORT=3001

# Optional: configure how /health resolves the backend version
# GITHUB_REPO_OWNER=marcossarres
# GITHUB_REPO_NAME=openai-dashboard
# GITHUB_VERSION_WORKFLOW=deploy-frontend.yml
# GITHUB_VERSION_TOKEN=<github_personal_access_token>
# HEALTH_VERSION_CACHE_MS=60000
